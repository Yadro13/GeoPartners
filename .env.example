# Application
APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAIL=admin@example.com

# Railway PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geopartners

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (available on Railway Pro)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=GeoPartners <no-reply@example.com>

# Optional Telegram admin notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Railway Object Storage (inject from the Bucket service)
AWS_ENDPOINT_URL=https://storage.railway.app
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_DEFAULT_REGION=auto
AWS_S3_URL_STYLE=virtual

# Restore safety (set only for a one-off restore command)
# RESTORE_DATABASE_URL must point to a separate recovery database.
RESTORE_DATABASE_URL=
RESTORE_CONFIRM_DATABASE=
